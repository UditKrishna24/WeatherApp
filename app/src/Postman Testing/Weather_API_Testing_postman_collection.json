  "item": [
    {
      "name": "TC01 - Valid Coordinates",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// =============================================",
              "// Test 1 - Verify Status Code is 200",
              "// =============================================",
              "pm.test(\"Status Code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// =============================================",
              "// Test 2 - Verify Response Time is less than 1000 ms",
              "// =============================================",
              "pm.test(\"Response Time is less than 1000 ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);",
              "});",
              "",
              "// Parse the JSON response once",
              "const json = pm.response.json();",
              "",
              "// =============================================",
              "// Test 3 - Verify City Name Exists",
              "// =============================================",
              "pm.test(\"City Name exists\", function () {",
              "    pm.expect(json.name).to.not.be.empty;",
              "});",
              "",
              "// =============================================",
              "// Test 4 - Verify Temperature Exists",
              "// =============================================",
              "pm.test(\"Temperature exists\", function () {",
              "    pm.expect(json.main.temp).to.not.be.undefined;",
              "});",
              "",
              "// =============================================",
              "// Test 5 - Verify Humidity Exists",
              "// =============================================",
              "pm.test(\"Humidity exists\", function () {",
              "    pm.expect(json.main.humidity).to.not.be.undefined;",
              "});",
              "",
              "// =============================================",
              "// Test 6 - Verify Weather Description Exists",
              "// =============================================",
              "pm.test(\"Weather Description exists\", function () {",
              "    pm.expect(json.weather[0].description).to.not.be.empty;",
              "});",
              "",
              "// =============================================",
              "// Test 7 - Verify Wind Speed Exists",
              "// =============================================",
              "pm.test(\"Wind Speed exists\", function () {",
              "    pm.expect(json.wind.speed).to.not.be.undefined;",
              "});",
              "",
              "// =============================================",
              "// Test 8 - Verify Response Content Type is JSON",
              "// =============================================",
              "pm.test(\"Content-Type is application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\"))",
              "        .to.include(\"application/json\");",
              "});",
              "",
              "// =============================================",
              "// Test 9 - Verify API returned Success",
              "// =============================================",
              "pm.test(\"API returned Success (cod = 200)\", function () {",
              "    pm.expect(json.cod).to.eql(200);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://api.openweathermap.org/data/2.5/weather?lat=13.0826&lon=80.2707&appid=407a3e410cf4360f80dc10f1b4b73bd7&units=metric",
